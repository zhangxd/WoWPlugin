{
  "contract": {
    "contract_id": "navigation_map_assignments",
    "schema_version": 2,
    "summary": "导航 UiMap 到 MapID 关系",
    "source_of_truth": "WoWPlugin",
    "status": "active"
  },
  "output": {
    "lua_file": "Toolbox/Data/NavigationMapAssignments.lua",
    "lua_table": "Toolbox.Data.NavigationMapAssignments",
    "write_header": true
  },
  "source": {
    "database": "wow.db",
    "tables": [
      "uimapassignment",
      "uimap"
    ],
    "sql": "SELECT 1 AS placeholder",
    "query": {
      "from": "uimapassignment",
      "joins": [
        "uimap ON uimap.ID = uimapassignment.UiMapID"
      ],
      "select": [
        "relation_key",
        "ui_map_id",
        "ui_map_name",
        "parent_ui_map_id",
        "ui_map_type",
        "map_id",
        "area_id",
        "order_index"
      ],
      "where": [
        "UiMapID > 0",
        "MapID >= 0",
        "只导出 UiMap <-> MapID 关系，不导出 Region / Ui 坐标字段"
      ],
      "group_by": [
        "ui_map_id",
        "map_id"
      ],
      "order_by": [
        "map_id ASC",
        "ui_map_id ASC"
      ],
      "row_granularity": "一行代表一个 UiMap 与 MapID 的关系"
    },
    "datasets": {
      "assignments": {
        "sql": "SELECT 'uimap_' || CAST(a.UiMapID AS TEXT) || '_map_' || CAST(a.MapID AS TEXT) AS relation_key, CAST(a.UiMapID AS INTEGER) AS ui_map_id, u.Name_lang AS ui_map_name, CAST(COALESCE(u.ParentUiMapID, 0) AS INTEGER) AS parent_ui_map_id, CAST(COALESCE(u.Type, 0) AS INTEGER) AS ui_map_type, CAST(a.MapID AS INTEGER) AS map_id, MIN(CAST(COALESCE(a.AreaID, 0) AS INTEGER)) AS area_id, MIN(CAST(COALESCE(a.OrderIndex, 0) AS INTEGER)) AS order_index FROM uimapassignment a LEFT JOIN uimap u ON CAST(u.ID AS INTEGER) = CAST(a.UiMapID AS INTEGER) WHERE CAST(a.ID AS INTEGER) > 0 AND CAST(a.UiMapID AS INTEGER) > 0 AND CAST(a.MapID AS INTEGER) >= 0 GROUP BY CAST(a.UiMapID AS INTEGER), u.Name_lang, CAST(COALESCE(u.ParentUiMapID, 0) AS INTEGER), CAST(COALESCE(u.Type, 0) AS INTEGER), CAST(a.MapID AS INTEGER) ORDER BY CAST(a.MapID AS INTEGER), CAST(a.UiMapID AS INTEGER)",
        "query": {
          "from": "uimapassignment",
          "joins": [
            "uimap ON uimap.ID = uimapassignment.UiMapID"
          ],
          "select": [
            "relation_key",
            "ui_map_id",
            "parent_ui_map_id",
            "ui_map_type",
            "map_id",
            "area_id",
            "order_index"
          ],
          "where": [
            "UiMapID > 0",
            "MapID >= 0"
          ],
          "group_by": [
            "ui_map_id",
            "map_id"
          ],
          "order_by": [
            "map_id ASC",
            "ui_map_id ASC"
          ],
          "row_granularity": "一行代表一个 UiMap 与 MapID 的关系"
        }
      }
    }
  },
