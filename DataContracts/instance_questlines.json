    "status": "active"
  },
  "output": {
    "lua_file": "Toolbox/Data/InstanceQuestlines.lua",
    "lua_table": "Toolbox.Data.InstanceQuestlines",
    "write_header": true
  },
  "source": {
    "database": "wow.db",
    "tables": [
      "questline",
      "questlinexquest",
      "campaign",
      "campaignxquestline",
      "questpoiblob",
      "uimap",
      "map"
    ],
    "sql": "SELECT 1 AS placeholder",
    "query": {
      "from": "placeholder",
      "joins": [],
      "select": [
        "placeholder"
      ],
      "where": [],
      "group_by": [],
      "order_by": [],
      "row_granularity": "占位查询"
    },
    "supplemental_sources": [
      {
        "type": "questcompletist",
        "dataset": "core_links",
        "env_var": "WOW_QUESTCOMPLETIST_DIR",
        "entry_file": "qcQuest.lua"
      }
    ],
    "datasets": {
      "core_links": {
        "sql": "SELECT DISTINCT\n  CAST(ql.ID AS INTEGER) AS quest_line_id,\n  ql.Name_lang AS quest_line_name,\n  CAST(qlxq.QuestID AS INTEGER) AS quest_id,\n  CAST(qlxq.OrderIndex AS INTEGER) AS order_index\nFROM questline ql\nJOIN questlinexquest qlxq ON qlxq.QuestLineID = ql.ID\nWHERE TRIM(ql.ID) <> ''\n  AND CAST(ql.ID AS INTEGER) > 0\n  AND CAST(qlxq.QuestID AS INTEGER) > 0\nORDER BY CAST(ql.ID AS INTEGER), CAST(qlxq.OrderIndex AS INTEGER), CAST(qlxq.QuestID AS INTEGER)",
        "query": {
          "from": "questline ql",
          "joins": [
            "questlinexquest qlxq ON qlxq.QuestLineID = ql.ID"
          ],
          "select": [
            "quest_line_id",
            "quest_line_name",
            "quest_id",
            "order_index"
          ],
          "where": [
            "quest_line_id > 0",
            "quest_id > 0"
          ],
          "group_by": [],
          "order_by": [
            "quest_line_id ASC",
            "order_index ASC",
            "quest_id ASC"
          ],
          "row_granularity": "一行代表一个任务线与任务关联"
        }
      }
    }
  },
