  "contract": {
    "contract_id": "instance_questlines",
    "schema_version": 1,
    "summary": "冒险手册任务页签静态任务线文档",
    "source_of_truth": "WoWPlugin",
    "status": "active"
  },
  "output": {
    "lua_file": "Toolbox/Data/InstanceQuestlines.lua",
    "lua_table": "Toolbox.Data.InstanceQuestlines",
    "write_header": true
  },
  "source": {
    "database": "wow.db",
    "tables": [
      "questline",
      "questlinexquest",
      "questpoiblob"
    ],
    "sql": "SELECT\n  CAST(ql.ID AS INTEGER) AS quest_line_id,\n  ql.Name_lang AS quest_line_name,\n  CAST(qlxq.QuestID AS INTEGER) AS quest_id,\n  CAST(qlxq.OrderIndex AS INTEGER) AS order_index,\n  CAST(qpb.UiMapID AS INTEGER) AS ui_map_id\nFROM questline ql\nJOIN questlinexquest qlxq ON qlxq.QuestLineID = ql.ID\nLEFT JOIN questpoiblob qpb ON qpb.QuestID = qlxq.QuestID\n  AND CAST(qpb.UiMapID AS INTEGER) > 0\nWHERE TRIM(ql.ID) <> ''\n  AND CAST(ql.ID AS INTEGER) > 0\n  AND CAST(qlxq.QuestID AS INTEGER) > 0\nORDER BY CAST(ql.ID AS INTEGER), CAST(qlxq.OrderIndex AS INTEGER), CAST(qlxq.QuestID AS INTEGER)",
    "query": {
      "from": "questline ql",
      "joins": [
        "questlinexquest qlxq ON qlxq.QuestLineID = ql.ID",
        "LEFT questpoiblob qpb ON qpb.QuestID = qlxq.QuestID AND qpb.UiMapID > 0"
      ],
      "select": [
        "quest_line_id",
        "quest_line_name",
        "quest_id",
        "order_index",
        "ui_map_id"
      ],
      "where": [
        "quest_line_id 非空",
        "quest_line_id > 0",
        "quest_id > 0"
      ],
      "group_by": [],
      "order_by": [
        "quest_line_id ASC",
        "order_index ASC",
        "quest_id ASC"
      ],
      "row_granularity": "一行代表一个任务线与任务的关联记录"
    }
  },
