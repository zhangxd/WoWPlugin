        "journal_instance_id"
      ]
    ],
    "non_null_fields": [
      "journal_instance_id",
      "map_id"
    ],
    "sort_rules": [
      {
        "field": "journal_instance_id",
        "direction": "asc"
      }
    ]
  },
  "versioning": {
